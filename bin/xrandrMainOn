#/bin/sh

# Displays definitions
. ~/.my-env

xrandr --output "$DISPLAY_1" --off --output "$DISPLAY_2" --off --output "$DISPLAY_DOCK_1" --off --output "$DISPLAY_DOCK_2" --off --output "$DISPLAY_3" --off --output "$DISPLAY_4" --off --output "$DISPLAY_DOCK_3" --off --output "$DISPLAY_DOCK_4" --off --output "$DISPLAY_DP3" --off --output "$DISPLAY_HDMI" --off --output "$DISPLAY_LAPTOP" --auto --primary

