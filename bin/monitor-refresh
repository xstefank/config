#!/bin/sh

source /home/mstefank/.my-env

readonly DISPLAY_NUM=$1
readonly MONITORS_NUM=$(xrandr --listmonitors | head -n 1 | sed 's/Monitors: //g')

if [[ "$DISPLAY_NUM" == 1 ]]; then
 xrandr --output "$DISPLAY_1" --off
 xrandr --output "$DISPLAY_1" --left-of "$DISPLAY_2" --auto
else
  readonly DISPLAY_RESTART=DISPLAY_$DISPLAY_NUM
  readonly DISPLAY_LEFT=DISPLAY_$(($DISPLAY_NUM-1))
  xrandr --output "${!DISPLAY_RESTART}" --off
  xrandr --output "${!DISPLAY_RESTART}" --right-of "${!DISPLAY_LEFT}" --auto
fi 

